<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.example.constructiondelivery">
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"/>
    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/landing_image"
        android:label="@string/app_name"
        android:roundIcon="@drawable/landing_image"
        android:supportsRtl="true"
        android:theme="@style/Theme.BuildHub"
        tools:targetApi="31">

        <!-- LANDING PAGE -->
        <activity
            android:name=".MainActivity"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

        </activity>

        <!-- OTHER ACTIVITIES -->
        <activity android:name=".LoginActivity" />
        <activity android:name=".SignupActivity" />
        <activity android:name=".AdminDashboardActivity" />
        <activity android:name=".UserDashboardActivity" />
        <activity android:name=".ProductDetailActivity" />
        <activity android:name=".CompareActivity" />
        <activity android:name=".ProductSelectionActivity" />
        <activity android:name=".CartActivity" />
        <activity android:name=".OrdersActivity" />
        <activity android:name=".AccountActivity" />
        <activity android:name=".EditProfileActivity" />
        <activity android:name=".SettingsActivity" />
        <activity android:name=".TermsActivity" />
        <activity android:name=".HelpCenterActivity" />
        <activity android:name=".RateAppActivity" />

        <activity android:name=".SavedAddressActivity" />
        <activity android:name=".BankDetailsActivity" />
        <activity android:name=".AddressActivity" />
        <activity
            android:name=".OrderSummaryActivity"
            android:theme="@style/Theme.BuildHub.NoActionBar" />
        <activity android:name=".SupplierLoginActivity" />
        <activity android:name=".SupplierSignupActivity" />
        <activity android:name=".SupplierDashboardActivity" />
        <activity android:name=".AddProductActivity" />
        <activity
            android:name=".ManageMaterialActivity"
            android:theme="@style/Theme.BuildHub.NoActionBar" />
        <activity
            android:name=".ViewOrderActivity"
            android:theme="@style/Theme.BuildHub.NoActionBar" />
        <activity
            android:name=".ManageUsersActivity"
            android:theme="@style/Theme.BuildHub.NoActionBar" />
        <activity
            android:name=".PaymentMethodActivity"
            android:theme="@style/Theme.BuildHub.NoActionBar" />
        <activity
            android:name=".OrderDetailActivity"
            android:theme="@style/Theme.BuildHub.NoActionBar" />

    </application>

</manifest>
